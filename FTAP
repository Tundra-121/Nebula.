    CurrentValue = false,
    Flag         = "KickGrabToggle",
    Callback     = function(v)
        kickGrabLoopEnabled = v
        if v then
            task.spawn(function()
                local target = grabBringTarget
                if not target then
                    Rayfield:Notify({ Title = "Kick Grab", Content = "Selectionne une cible !", Duration = 3 })
                    kickGrabLoopEnabled = false
                    return
                end

                local myChar = LocalPlayer.Character
                local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
                if not myHRP then kickGrabLoopEnabled = false return end

                local tChar = workspace:FindFirstChild(target)
                local tHRP  = tChar and tChar:FindFirstChild("HumanoidRootPart")
                if not tHRP then
                    Rayfield:Notify({ Title = "Kick Grab", Content = "Joueur introuvable !", Duration = 3 })
                    kickGrabLoopEnabled = false
                    return
                end

                -- Grab initial
                local savedCF = myHRP.CFrame
                myHRP.CFrame = tHRP.CFrame * CFrame.new(0, 0, -2)
                task.wait(0.1)

                local grabbed = false
                for i = 1, 20 do
                    if not kickGrabLoopEnabled then break end
                    pcall(function()
                        RemoteSetNetwork:FireServer(tHRP, tHRP.CFrame)
                    end)
                    local tHead = tChar:FindFirstChild("Head")
                    if tHead and tHead:FindFirstChild("PartOwner") and tHead.PartOwner.Value == LocalPlayer.Name then
                        grabbed = true
                        break
                    end
                    task.wait()
                end

                if not grabbed then
                    Rayfield:Notify({ Title = "Kick Grab", Content = "Grab echoue !", Duration = 3 })
                    myHRP.CFrame = savedCF
                    kickGrabLoopEnabled = false
                    return
                end

                task.wait(0.1)
                myHRP.CFrame = savedCF
                task.wait(0.2)
                pcall(function() RemoteDestroyGrab:FireServer(tHRP) end)

                Rayfield:Notify({ Title = "Kick Grab", Content = "Actif sur @" .. target, Duration = 3 })

                -- Boucle principale
                while kickGrabLoopEnabled do
                    local myCharL = LocalPlayer.Character
                    local myHRPL  = myCharL and myCharL:FindFirstChild("HumanoidRootPart")
                    if not myHRPL then break end

                    local tCharL = workspace:FindFirstChild(target)
                    local tHRPL  = tCharL and tCharL:FindFirstChild("HumanoidRootPart")

                    if tHRPL then
                        -- Re-grab si trop loin
                        if (myHRPL.Position - tHRPL.Position).Magnitude > 36 then
                            local curPos = myHRPL.CFrame
                            myHRPL.CFrame = tHRPL.CFrame * CFrame.new(0, 0, -2)
                            task.wait(0.1)
                            for i = 1, 20 do
                                if not kickGrabLoopEnabled then break end
                                pcall(function() RemoteSetNetwork:FireServer(tHRPL, tHRPL.CFrame) end)
                                local tH2 = tCharL:FindFirstChild("Head")
                                if tH2 and tH2:FindFirstChild("PartOwner") and tH2.PartOwner.Value == LocalPlayer.Name then break end
                                task.wait()
                            end
                            myHRPL.CFrame = curPos
                            task.wait(0.2)
                            pcall(function() RemoteDestroyGrab:FireServer(tHRPL) end)
                        end

                        -- Spam SetNetworkOwner + tp en hauteur
                        local tH = tCharL:FindFirstChild("Head")
                        local isGrabbed = tH and tH:FindFirstChild("PartOwner") and tH.PartOwner.Value == LocalPlayer.Name
                        if isGrabbed then
                            pcall(function()
                                RemoteSetNetwork:FireServer(tHRPL, tHRPL.CFrame)
                                RemoteDestroyGrab:FireServer(tHRPL)
                                tHRPL.CFrame = myHRPL.CFrame * CFrame.new(0, 20, 0)
                                tHRPL.AssemblyLinearVelocity  = Vector3.zero
                                tHRPL.AssemblyAngularVelocity = Vector3.zero
                            end)
                        else
                            pcall(function() RemoteSetNetwork:FireServer(tHRPL, tHRPL.CFrame) end)
                        end
                        task.wait()
                    else
                        -- Cible partie, attendre le retour
                        while kickGrabLoopEnabled do
                            task.wait(1)
                            local tCharW = workspace:FindFirstChild(target)
                            local tHRPW  = tCharW and tCharW:FindFirstChild("HumanoidRootPart")
                            if tHRPW then
                                -- Re-grab
                                local sp = myHRPL.CFrame
                                myHRPL.CFrame = tHRPW.CFrame * CFrame.new(0, 0, -2)
                                task.wait(0.1)
                                for i = 1, 20 do
                                    if not kickGrabLoopEnabled then break end
                                    pcall(function() RemoteSetNetwork:FireServer(tHRPW, tHRPW.CFrame) end)
                                    local tH3 = tCharW:FindFirstChild("Head")
                                    if tH3 and tH3:FindFirstChild("PartOwner") and tH3.PartOwner.Value == LocalPlayer.Name then break end
                                    task.wait()
                                end
                                myHRPL.CFrame = sp
                                task.wait(0.2)
                                pcall(function() RemoteDestroyGrab:FireServer(tHRPW) end)
                                break
                            end
                        end
                    end
                end

                Rayfield:Notify({ Title = "Kick Grab", Content = "Desactive !", Duration = 2 })
            end)
        else
            Rayfield:Notify({ Title = "Kick Grab", Content = "Desactive !", Duration = 2 })
        end
    end,
})


