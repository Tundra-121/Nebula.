-- Touche X pour selectionner la cible visee
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if not puppetEnabled then return end
    if input.KeyCode ~= Enum.KeyCode.X then return end

    local cam     = workspace.CurrentCamera
    local center  = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
    local closest      = nil
    local closestDist  = 200
    local closestModel = nil  -- le model (joueur ou ragdoll)

    -- Chercher joueurs
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local pos, visible = cam:WorldToViewportPoint(hrp.Position)
                if visible then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist < closestDist then
                        closestDist  = dist
                        closest      = p
                        closestModel = p.Character
                    end
                end
            end
        end
    end

    -- Chercher ragdolls / clones / modeles avec Humanoid dans workspace
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= LocalPlayer.Character then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            -- Verifier que c'est pas un perso de joueur deja traite
            local isPlayerChar = false
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character == obj then isPlayerChar = true break end
            end
            if not isPlayerChar and hum and hrp then
                local pos, visible = cam:WorldToViewportPoint(hrp.Position)
                if visible then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist < closestDist then
                        closestDist  = dist
                        closest      = nil  -- pas un joueur
                        closestModel = obj
                    end
                end
            end
        end
    end

    if not closestModel then
        Rayfield:Notify({ Title = "Puppet Control", Content = "Aucune cible visee !", Duration = 2 })
        return
    end

    -- Stopper l'ancien puppet
    if puppetConn    then puppetConn:Disconnect()    puppetConn    = nil end
    if puppetCamConn then puppetCamConn:Disconnect() puppetCamConn = nil end
    puppetRestoreCamera()

    puppetTarget = closestModel
    local targetName = closest and closest.Name or closestModel.Name
    -- Sauvegarder la position des membres avant de prendre le controle
    puppetSaveLimbs(closestModel)
    Rayfield:Notify({ Title = "Puppet Control", Content = "Controle de : " .. targetName, Duration = 3 })

    -- Boucle principale : coller notre HRP sous le HRP de la cible + la diriger
    puppetConn = RunService.Heartbeat:Connect(function()
        if not puppetEnabled or not puppetTarget or not puppetTarget.Parent then
            puppetConn:Disconnect() puppetConn = nil
            puppetRestoreCamera()
            puppetTarget = nil
            return
        end

        local myChar = LocalPlayer.Character
        local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local myHum  = myChar and myChar:FindFirstChildOfClass("Humanoid")
        local tHRP   = puppetTarget:FindFirstChild("HumanoidRootPart")
        local tHum   = puppetTarget:FindFirstChildOfClass("Humanoid")

        if not myHRP or not tHRP or not tHum then return end

        -- On se colle juste en dessous de la cible (invisible pour les autres)
        myHRP.CFrame = tHRP.CFrame * CFrame.new(0, -50, 0)
        myHRP.AssemblyLinearVelocity  = Vector3.zero
        myHRP.AssemblyAngularVelocity = Vector3.zero

        -- Copier le mouvement de notre humanoid vers la cible
        if myHum and tHum then
            local moveDir = myHum.MoveDirection
            if moveDir.Magnitude > 0 then
                tHum.WalkSpeed = 16
                tHRP.AssemblyLinearVelocity = Vector3.new(
                    moveDir.X * 16,
                    tHRP.AssemblyLinearVelocity.Y,
                    moveDir.Z * 16
                )
            else
                tHRP.AssemblyLinearVelocity = Vector3.new(
                    0,
                    tHRP.AssemblyLinearVelocity.Y,
                    0
                )
            end
        end

        -- Masquer les parts genantes de la cible
        puppetHideParts(puppetTarget)
    end)

    -- Camera sur la tete de la cible avec rotation libre
    local camPuppet = workspace.CurrentCamera
    camPuppet.CameraType = Enum.CameraType.Custom

    puppetCamConn = RunService.RenderStepped:Connect(function()
        if not puppetEnabled or not puppetTarget or not puppetTarget.Parent then
            puppetCamConn:Disconnect() puppetCamConn = nil
            puppetRestoreCamera()
            return
        end
        local tHead = puppetTarget:FindFirstChild("Head")
        if tHead then
            camPuppet.CameraSubject = tHead
        end
    end)
end)

