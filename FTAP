-- Logique Look TP : tp la ou regarde la camera
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if listeningForKey then return end  -- on est en mode ecoute, pas tp
    if not lookTPEnabled then return end
    if input.KeyCode ~= lookTPKey then return end

    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local cam     = workspace.CurrentCamera
    local ray     = cam:ScreenPointToRay(
        cam.ViewportSize.X / 2,
        cam.ViewportSize.Y / 2
    )

    -- Raycast dans la direction du regard
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {char}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude

    local result = workspace:Raycast(ray.Origin, ray.Direction * 500, rayParams)

    local targetPos
    if result then
        -- Tp sur le point vise + offset hauteur
        targetPos = result.Position + Vector3.new(0, 3, 0)
    else
        -- Rien en vue : tp 50 studs devant la camera
        targetPos = ray.Origin + ray.Direction * 50
    end

    hrp.CFrame = CFrame.new(targetPos)
end)



