local antiKickEnabled      = false
local antiKickConn         = nil
local lastSafePosition     = nil
local antiKickNinjaKunai   = nil
local antiKickSkyThreshold = 500

local function placeKunaiInTorso()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Chercher un kunai existant dans les toys des joueurs
    for _, p in ipairs(Players:GetPlayers()) do
        local tf = workspace:FindFirstChild(p.Name .. "SpawnedInToys")
        if tf then
            for _, item in ipairs(tf:GetChildren()) do
                if item.Name == "NinjaKunai" then
                    local sp = item:FindFirstChild("SoundPart")
                    if sp and sp:IsA("BasePart") then
                        pcall(function()
                            RemoteSetNetwork:FireServer(sp, sp.CFrame)
                            sp.CFrame     = hrp.CFrame
                            sp.CanCollide = false
                            sp.CanTouch   = false
                            sp.Massless   = true
                            sp.AssemblyLinearVelocity  = Vector3.zero
                            sp.AssemblyAngularVelocity = Vector3.zero
                        end)
                        antiKickNinjaKunai = sp
                        return
                    end
                end
            end
        end
    end
    -- Spawner notre propre kunai
    pcall(function()
        SpawnToyRF:InvokeServer("NinjaKunai", hrp.CFrame, Vector3.new(0, 97.69, 0))
    end)
    task.wait(0.1)
    local tf2 = workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
    if tf2 then
        local kunai = tf2:FindFirstChild("NinjaKunai")
        if kunai then
            local sp = kunai:FindFirstChild("SoundPart")
            if sp then
                pcall(function()
                    RemoteSetNetwork:FireServer(sp, sp.CFrame)
                    sp.CFrame     = hrp.CFrame
                    sp.CanCollide = false
                    sp.CanTouch   = false
                    sp.Massless   = true
                    sp.AssemblyLinearVelocity  = Vector3.zero
                    sp.AssemblyAngularVelocity = Vector3.zero
                end)
                antiKickNinjaKunai = sp
            end
        end
    end
end

