local function breakLimbs(targetChar)
    -- TP bras et jambes
    for _, v in pairs(targetChar:GetDescendants()) do
        if v:IsA("BasePart") and (
            v.Name == "Left Arm"       or v.Name == "Right Arm"      or
            v.Name == "Left Leg"       or v.Name == "Right Leg"      or
            v.Name == "LeftUpperArm"   or v.Name == "RightUpperArm"  or
            v.Name == "LeftLowerArm"   or v.Name == "RightLowerArm"  or
            v.Name == "LeftHand"       or v.Name == "RightHand"      or
            v.Name == "LeftUpperLeg"   or v.Name == "RightUpperLeg"  or
            v.Name == "LeftLowerLeg"   or v.Name == "RightLowerLeg"  or
            v.Name == "LeftFoot"       or v.Name == "RightFoot"
        ) then
            pcall(function()
                v.CFrame = CFrame.new(0, -10000, 0)
            end)
        end
    end

    -- Spawn pallet sur lui
    local hrp = targetChar:FindFirstChild("HumanoidRootPart")
    if hrp then
        pcall(function()
            SpawnToyRF:InvokeServer(
                "PalletLightBrown",
                hrp.CFrame,
                Vector3.new(0, 97.69, 0)
            )
        end)
        task.wait(0.1)
        -- Detruire le pallet juste apres (pour eviter qu il reste)
        local toysFolder = workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
        if toysFolder then
            local pallet = toysFolder:FindFirstChild("PalletLightBrown")
            if pallet then
                pcall(function() DestroyToy:FireServer(pallet) end)
            end
        end
    end
end

