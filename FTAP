TabFun:CreateSection("Puppet Control")

local puppetEnabled      = false
local puppetTarget       = nil
local puppetConn         = nil
local puppetCamConn      = nil
local puppetHiddenParts  = {}
local puppetSavedLimbs   = {}  -- sauvegarde des CFrame des membres

local function puppetSaveLimbs(char)
    puppetSavedLimbs = {}
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and (
            part.Name == "Left Arm"     or part.Name == "Right Arm"     or
            part.Name == "Left Leg"     or part.Name == "Right Leg"     or
            part.Name == "LeftUpperArm" or part.Name == "RightUpperArm" or
            part.Name == "LeftLowerArm" or part.Name == "RightLowerArm" or
            part.Name == "LeftHand"     or part.Name == "RightHand"     or
            part.Name == "LeftUpperLeg" or part.Name == "RightUpperLeg" or
            part.Name == "LeftLowerLeg" or part.Name == "RightLowerLeg" or
            part.Name == "LeftFoot"     or part.Name == "RightFoot"
        ) then
            table.insert(puppetSavedLimbs, { part = part, cf = part.CFrame })
        end
    end
end

local function puppetRestoreLimbs()
    for _, data in ipairs(puppetSavedLimbs) do
        pcall(function()
            if data.part and data.part.Parent then
                data.part.CFrame = data.cf
            end
        end)
    end
    puppetSavedLimbs = {}
end

local function puppetRestoreCamera()
    local cam = workspace.CurrentCamera
    cam.CameraType = Enum.CameraType.Custom
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        cam.CameraSubject = char.Humanoid
    end
    -- Restaurer la transparence des parts cachees
    for _, data in ipairs(puppetHiddenParts) do
        pcall(function()
            if data.part and data.part.Parent then
                data.part.LocalTransparencyModifier = data.mod or 0
            end
        end)
    end
    puppetHiddenParts = {}
end

local function puppetHideParts(char)
    puppetHiddenParts = {}
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("BasePart") and (
            obj.Name == "Head" or obj.Name == "UpperTorso" or obj.Name == "Torso"
        ) then
            table.insert(puppetHiddenParts, { part = obj, mod = obj.LocalTransparencyModifier })
            obj.LocalTransparencyModifier = 1
        end
        if obj:IsA("BasePart") or obj:IsA("MeshPart") then
            local p = obj.Parent
            if p and (p:IsA("Accessory") or p:IsA("Hat")) then
                table.insert(puppetHiddenParts, { part = obj, mod = obj.LocalTransparencyModifier })
                obj.LocalTransparencyModifier = 1
            end
        end
    end
end

