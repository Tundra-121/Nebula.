-- Masquer les accessoires/cheveux qui genent la vue
local function hideCamParts(character)
    camHiddenParts = {}
    for _, obj in ipairs(character:GetDescendants()) do
        -- Masquer les parts des accessoires (chapeaux, cheveux, etc)
        if obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("SpecialMesh") then
            local parent = obj.Parent
            if parent and (parent:IsA("Accessory") or parent:IsA("Hat") or parent.Name == "Hair"
                or parent.Name == "HairAccessory" or parent.Name == "FaceAccessory"
                or parent.Name == "HatAccessory" or parent.Name == "NeckAccessory"
                or parent.Name == "WaistAccessory" or parent.Name == "BackAccessory") then
                if obj:IsA("BasePart") or obj:IsA("MeshPart") then
                    local oldTrans = obj.LocalTransparencyModifier
                    table.insert(camHiddenParts, { part = obj, transparency = obj.Transparency })
                    obj.LocalTransparencyModifier = 1
                end
            end
        end
        -- Masquer aussi le Head et le torse pour eviter qu ils genent
        if obj:IsA("BasePart") and (obj.Name == "Head" or obj.Name == "UpperTorso" or obj.Name == "Torso") then
            table.insert(camHiddenParts, { part = obj, mod = obj.LocalTransparencyModifier })
            obj.LocalTransparencyModifier = 1
        end
    end
end

local function restoreCamParts()
    for _, data in ipairs(camHiddenParts) do
        pcall(function()
            if data.part and data.part.Parent then
                data.part.LocalTransparencyModifier = data.mod or 0
            end
        end)
    end
    camHiddenParts = {}
end

