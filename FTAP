-- Helpers Target Kick
local selectedTarget = nil

local function isPlayerValid(targetName)
    local p = Players:FindFirstChild(targetName)
    if not p or not p.Character then return false end
    return p.Character:FindFirstChild("HumanoidRootPart") ~= nil
end

local function isPlayerDead(targetName)
    local p = Players:FindFirstChild(targetName)
    if not p or not p.Character then return true end
    local hum = p.Character:FindFirstChild("Humanoid")
    return not hum or hum.Health <= 0
end

local function getCurrentBlob()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hum  = char:FindFirstChild("Humanoid")
    if not hum then return nil end
    local seat = hum.SeatPart
    if not seat then return nil end
    if seat.Parent and seat.Parent.Name == "CreatureBlobman" then
        local toysFolder = workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
        if toysFolder and seat.Parent.Parent == toysFolder then
            return seat.Parent
        end
    end
    return nil
end

local function spawnAndSit()
    local root = LocalPlayer.Character.HumanoidRootPart
    SpawnToyRF:InvokeServer("CreatureBlobman", root.CFrame, Vector3.new(0, 97.69, 0))
    task.wait(0.2)
    local toysFolder = workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
    if toysFolder then
        local blob = toysFolder:FindFirstChild("CreatureBlobman")
        if blob then
            local rightDetector = blob:FindFirstChild("RightDetector")
            if rightDetector then
                pcall(function()
                    local rAO = rightDetector:FindFirstChild("RightAlignOrientation")
                    if rAO then rAO.Enabled = false end
                end)
            end
            local seat = blob:FindFirstChild("VehicleSeat")
            if seat then seat:Sit(LocalPlayer.Character.Humanoid) end
        end
    end
    task.wait(0.2)
end

local function resetTarget(targetHRP)
    pcall(function()
        RemoteDestroyGrab:FireServer(targetHRP)
        task.wait(0.1)
        RemoteSetNetwork:FireServer(targetHRP, targetHRP.CFrame)
        task.wait(0.1)
        RemoteDestroyGrab:FireServer(targetHRP)
        task.wait(0.2)
    end)
end

local function emergencyUngrab(blob)
    pcall(function()
        if blob:FindFirstChild("RightDetector") then
            local weld = blob.RightDetector:FindFirstChild("RightWeld")
            if weld and weld.Part1 then
                blob.BlobmanSeatAndOwnerScript.CreatureRelease:FireServer(weld, weld.Part1)
                RemoteDestroyGrab:FireServer(weld.Part1)
            end
        end
    end)
end

local function grabWithRightArm(targetName, blob)
    local p = Players:FindFirstChild(targetName)
    if not p or not p.Character then return end
    local tHRP = p.Character:FindFirstChild("HumanoidRootPart")
    if not tHRP then return end
    pcall(function()
        blob.BlobmanSeatAndOwnerScript.CreatureGrab:FireServer(
            blob.RightDetector, tHRP, blob.RightDetector.RightWeld)
    end)
end

