-- ---- Section ESP BillboardGui (avatar couleur + nom) ----
TabVisual:CreateSection("ESP")

local espEnabled = false
local espBills   = {}  -- { player = BillboardGui }
local espColor   = Color3.fromRGB(255, 255, 255)

local function createESPForPlayer(player)
    if player == LocalPlayer then return end
    if espBills[player] then return end
    local char = player.Character
    local head = char and char:FindFirstChild("Head")
    if not head then return end

    -- BillboardGui attache a la tete, visible a travers les murs (AlwaysOnTop)
    local bill = Instance.new("BillboardGui")
    bill.Name             = "ESP_Bill"
    bill.Adornee          = head
    bill.Size             = UDim2.new(0, 60, 0, 80)
    bill.StudsOffset      = Vector3.new(0, 2.5, 0)
    bill.AlwaysOnTop      = true
    bill.LightInfluence   = 0
    bill.ResetOnSpawn     = false
    bill.Parent           = head

    -- Frame conteneur
    local frame = Instance.new("Frame")
    frame.Size            = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1
    frame.Parent          = bill

    -- Image avatar (headshot couleur)
    local img = Instance.new("ImageLabel")
    img.Size              = UDim2.new(0, 48, 0, 48)
    img.Position          = UDim2.new(0.5, -24, 0, 0)
    img.BackgroundTransparency = 1
    img.Image             = "rbxthumb://type=AvatarHeadShot&id=" .. player.UserId .. "&w=48&h=48"
    img.Parent            = frame

    -- Coins arrondis sur l'image
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent       = img

    -- Nom: DisplayName (@username)
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size            = UDim2.new(1, 0, 0, 20)
    nameLabel.Position        = UDim2.new(0, 0, 1, -22)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text            = player.DisplayName .. " (@" .. player.Name .. ")"
    nameLabel.TextColor3      = espColor
    nameLabel.TextScaled      = true
    nameLabel.Font            = Enum.Font.GothamBold
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.Parent          = frame

    espBills[player] = bill
end

local function removeESPForPlayer(player)
    if espBills[player] then
        espBills[player]:Destroy()
        espBills[player] = nil
    end
end

local function startESP()
    for _, p in ipairs(Players:GetPlayers()) do
        createESPForPlayer(p)
    end
end

local function stopESP()
    for player, _ in pairs(espBills) do
        removeESPForPlayer(player)
    end
end

