TabTarget:CreateSection("Target Kick (Blob)")

local function tgtGetCurrentBlob()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hum  = char:FindFirstChild("Humanoid")
    if not hum then return nil end
    local seat = hum.SeatPart
    if not seat then return nil end
    if seat.Parent and seat.Parent.Name == "CreatureBlobman" then
        local tf = workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
        if tf and seat.Parent.Parent == tf then return seat.Parent end
    end
    return nil
end

local function tgtSpawnAndSit()
    local root = LocalPlayer.Character.HumanoidRootPart
    SpawnToyRF:InvokeServer("CreatureBlobman", root.CFrame, Vector3.new(0, 97.69, 0))
    task.wait(0.2)
    local tf = workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
    if tf then
        local blob = tf:FindFirstChild("CreatureBlobman")
        if blob then
            local rd = blob:FindFirstChild("RightDetector")
            if rd then pcall(function()
                local rao = rd:FindFirstChild("RightAlignOrientation")
                if rao then rao.Enabled = false end
            end) end
            local seat = blob:FindFirstChild("VehicleSeat")
            if seat then seat:Sit(LocalPlayer.Character.Humanoid) end
        end
    end
    task.wait(0.2)
end

TabTarget:CreateButton({
    Name = "Target Kick (Blob)",
    Callback = function()
        if not tgtSelected then
            Rayfield:Notify({ Title = "Target Kick", Content = "Selectionne une cible !", Duration = 3 }) return
        end
        task.spawn(function()
            local blob = tgtGetCurrentBlob()
            if not blob then
                local char = LocalPlayer.Character
                local hum  = char and char:FindFirstChild("Humanoid")
                if hum and hum.SeatPart then hum.Sit = false task.wait(0.2) end
                tgtSpawnAndSit()
                blob = tgtGetCurrentBlob()
            end
            if not blob then
                Rayfield:Notify({ Title = "Target Kick", Content = "Blob introuvable !", Duration = 3 }) return
            end
            local tp = Players:FindFirstChild(tgtSelected)
            if not tp or not tp.Character then
                Rayfield:Notify({ Title = "Target Kick", Content = "Joueur introuvable !", Duration = 3 }) return
            end
            local tHRP = tp.Character:FindFirstChild("HumanoidRootPart")
            if not tHRP then return end
            local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if myHRP then myHRP.CFrame = tHRP.CFrame * CFrame.new(0, 3, 0) end

            -- Reset grab
            pcall(function()
                RemoteDestroyGrab:FireServer(tHRP)
                task.wait(0.1)
                RemoteSetNetwork:FireServer(tHRP, tHRP.CFrame)
                task.wait(0.1)
                RemoteDestroyGrab:FireServer(tHRP)
                task.wait(0.2)
            end)

