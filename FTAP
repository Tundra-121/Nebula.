local Debris = game:GetService("Debris")

-- BindableEvent pour detecter le grab (meme systeme que le jeu)
local FlingGrabEvent = Instance.new("BindableEvent")
FlingGrabEvent.Name   = "FlingGrabEvent"
FlingGrabEvent.Parent = workspace

local laserEnabled   = false
local flingGrabConn  = nil
local flingRelConn   = nil
local lastFlingGrab  = nil
local laserForce     = 1000000
local laserDuration  = 0.2

-- Detecte le grab via le GrabParts du workspace
local function GetMyGrabbedFling()
    local grabFolder = workspace:FindFirstChild("GrabParts")
    if not grabFolder then return nil end
    local grabPart = grabFolder:FindFirstChild("GrabPart")
    if not grabPart then return nil end
    local weld = grabPart:FindFirstChild("WeldConstraint") or grabPart:FindFirstChild("Weld")
    if not weld then return nil end
    local target = weld.Part1 and weld.Part1.Parent or weld.Part0 and weld.Part0.Parent
    if target == LocalPlayer.Character then return nil end
    return target
end

local function doFlingLaser(object)
    local isPlayer = false
    local targetHRP = nil
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character == object then
            isPlayer = true
            targetHRP = object:FindFirstChild("HumanoidRootPart")
            break
        end
    end

    local dir = workspace.CurrentCamera.CFrame.LookVector

    if isPlayer and targetHRP then
        pcall(function()
            RemoteSetNetwork:FireServer(targetHRP, targetHRP.CFrame)
        end)
        task.delay(0.01, function()
            targetHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            local bv = Instance.new("BodyVelocity")
            bv.Velocity  = dir * laserForce
            bv.MaxForce  = Vector3.new(1e9, 1e9, 1e9)
            bv.P         = 1e9
            bv.Parent    = targetHRP
            Debris:AddItem(bv, laserDuration)
        end)
    else
        local rootPart = object:FindFirstChildWhichIsA("BasePart")
        if rootPart then
            rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            local bv = Instance.new("BodyVelocity")
            bv.Velocity  = dir * laserForce
            bv.MaxForce  = Vector3.new(1e9, 1e9, 1e9)
            bv.P         = 1e9
            bv.Parent    = rootPart
            Debris:AddItem(bv, laserDuration)
        end
    end
end

