local TabInvi = Window:CreateTab("Invicibility", 4483362458)
TabInvi:CreateSection("Invicibility")

local AntiGrabEnabled   = false
local lastGrabbedState  = false
local lastGrabCount     = 0
local agConnection      = nil
local agRagdollConn     = nil
local velocityStartTime = nil

local struggleEvent = pcall(function() return ReplicatedStorage.CharacterEvents.Struggle end) and ReplicatedStorage.CharacterEvents.Struggle or nil
local ragdollRemote = pcall(function() return ReplicatedStorage.CharacterEvents.RagdollRemote end) and ReplicatedStorage.CharacterEvents.RagdollRemote or nil

local function AmIGrabbed()
    local character = LocalPlayer.Character
    if not character then return false, 0 end
    local grabCount = 0
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= LocalPlayer then
            local playerFolder = workspace:FindFirstChild(otherPlayer.Name)
            if playerFolder then
                local grabParts = playerFolder:FindFirstChild("GrabParts")
                if grabParts then
                    for _, grabPart in ipairs(grabParts:GetChildren()) do
                        if grabPart.Name == "GrabPart" then
                            local weld = grabPart:FindFirstChild("WeldConstraint") or grabPart:FindFirstChild("Weld")
                            if weld and weld.Part1 and weld.Part1:IsDescendantOf(character) then
                                grabCount += 1
                            end
                        end
                    end
                end
            end
        end
    end
    return grabCount > 0, grabCount
end

TabInvi:CreateToggle({
    Name = "Anti Grab",
    CurrentValue = false,
    Flag = "AntiGrabToggle",
    Callback = function(Value)
        AntiGrabEnabled = Value
        if AntiGrabEnabled then
            if agConnection then agConnection:Disconnect() end
            agConnection = RunService.Heartbeat:Connect(function()
                local character = LocalPlayer.Character
                if not character then return end
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                local isGrabbed, grabCount = AmIGrabbed()
                if isGrabbed and (not lastGrabbedState or grabCount ~= lastGrabCount) then
                    lastGrabbedState = true
                    lastGrabCount    = grabCount
                    velocityStartTime = tick()
                    local startTime  = tick()
                    local toggleAnch = false
                    if agRagdollConn then agRagdollConn:Disconnect() end
                    agRagdollConn = RunService.Heartbeat:Connect(function()
                        local elapsed = tick() - startTime
                        if elapsed < 1.67 then
                            toggleAnch = not toggleAnch
                            hrp.Anchored = toggleAnch
                            if ragdollRemote then pcall(function() ragdollRemote:FireServer(hrp, 1) end) end
                        elseif elapsed < 2 then
                            hrp.Anchored = false
                            if ragdollRemote then pcall(function() ragdollRemote:FireServer(hrp, 0) end) end
                        else
                            agRagdollConn:Disconnect()
                            agRagdollConn = nil
                        end
                    end)
                end
                if velocityStartTime then
                    if tick() - velocityStartTime < 1 then
                        hrp.AssemblyLinearVelocity  = Vector3.new(0,0,0)
                        hrp.AssemblyAngularVelocity = Vector3.new(0,0,0)
                    else
                        velocityStartTime = nil
                    end
                end
                if isGrabbed and struggleEvent then
                    pcall(function() struggleEvent:FireServer() end)
                end
                if not isGrabbed then
                    lastGrabbedState = false
                    lastGrabCount    = 0
                end
            end)
            Rayfield:Notify({ Title = "Anti Grab", Content = "ACTIVE !", Duration = 3 })
        else
            if agConnection    then agConnection:Disconnect()    agConnection    = nil end
            if agRagdollConn   then agRagdollConn:Disconnect()  agRagdollConn   = nil end
            local char = LocalPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then hrp.Anchored = false end
            end
            velocityStartTime = nil
            Rayfield:Notify({ Title = "Anti Grab", Content = "DESACTIVE.", Duration = 3 })
        end
    end,
})

