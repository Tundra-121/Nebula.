TabGrab:CreateToggle({
    Name         = "Bang",
    CurrentValue = false,
    Flag         = "BangToggle",
    Callback     = function(v)
        bangEnabled = v
        if v then
            if not bangTarget then
                Rayfield:Notify({ Title = "Bang", Content = "Selectionne une cible d'abord !", Duration = 3 })
                bangEnabled = false
                return
            end

            if bangConn then bangConn:Disconnect() end
            bangConn = RunService.Heartbeat:Connect(function(dt)
                if not bangEnabled then return end

                local target = Players:FindFirstChild(bangTarget)
                if not target or not target.Character then return end

                local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
                local tHum = target.Character:FindFirstChildOfClass("Humanoid")
                if not tHRP or not tHum then return end

                local myChar = LocalPlayer.Character
                local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
                if not myHRP then return end

                -- Mettre le joueur en ragdoll allonge face au sol
                pcall(function()
                    -- Ragdoll via RagdollRemote si dispo
                    local rr = ReplicatedStorage:FindFirstChild("CharacterEvents")
                    if rr then
                        local ragdollRemote = rr:FindFirstChild("RagdollRemote")
                        if ragdollRemote then
                            ragdollRemote:FireServer(tHRP, 1)
                        end
                    end
                end)

                -- Orienter la cible face au sol (rotation X 90 degres)
                pcall(function()
                    RemoteSetNetwork:FireServer(tHRP, tHRP.CFrame)
                    tHRP.CFrame = CFrame.new(tHRP.Position) * CFrame.Angles(math.rad(90), 0, 0)
                end)

                -- Va et vient devant le personnage
                bangTimer = bangTimer + dt
                local speed    = 3
                local distance = 0.8
                local offset   = math.sin(bangTimer * speed * math.pi) * distance

                -- Position : devant nous a ~3 studs, en bas
                -- Orientation : X=90 = couche face au sol (dos vers le ciel)
                -- Pour avoir le ventre vers le sol on fait X=-90
                local basePos = myHRP.CFrame * CFrame.new(0, -0.5, -(4.0 + offset))

                pcall(function()
                    RemoteSetNetwork:FireServer(tHRP, tHRP.CFrame)
                    -- Prendre la rotation horizontale du joueur local (yaw seulement)
                    local _, yaw, _ = myHRP.CFrame:ToEulerAnglesYXZ()
                    tHRP.CFrame = CFrame.new(basePos.Position)
                        * CFrame.Angles(0, yaw, 0)          -- meme direction que nous
                        * CFrame.Angles(math.rad(-90), 0, 0) -- penche face au sol
                end)
            end)

            Rayfield:Notify({
                Title   = "Bang",
                Content = "Actif sur @" .. bangTarget,
                Duration = 3,
            })
        else
            if bangConn then bangConn:Disconnect() bangConn = nil end
            bangTimer = 0
            Rayfield:Notify({
                Title   = "Bang",
                Content = "Desactive",
                Duration = 3,
            })
        end
    end,
})


